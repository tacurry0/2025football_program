{
  "name": "takarei app",
  "short_name": "takarei",
  "description": "J-League Match & Standings Tracker for Niigata and Kumamoto",
  "start_url": "index.html",
  "display": "standalone",
  "orientation": "portrait",
  "background_color": "#ffffff",
  "theme_color": "#ff6600",
  "icons": [
    {
      "src": "icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    }
  ],
  "prefer_related_applications": false,
  "shortcuts": [
    {
      "name": "Feed View",
      "url": "index.html?mode=feed",
      "description": "Open recently matches"
    },
    {
      "name": "Calendar View",
      "url": "index.html?mode=calendar",
      "description": "Check match calendar"
    }
  ]
}
